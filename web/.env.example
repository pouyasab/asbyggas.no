# Resend (https://resend.com) — legg til i Vercel → Settings → Environment Variables
# Lokalt: kopier til .env.local og fyll inn

RESEND_API_KEY=re_xxxxxxxx

# Avsender: må være et domene du har verifisert i Resend (f.eks. kontakt@asbyggas.no)
RESEND_FROM=A.S Bygg AS <kontakt@asbyggas.no>

# Valgfritt: hvor henvendelser lander (standard er info@asbyggas.no)
CONTACT_EMAIL_TO=info@asbyggas.no
