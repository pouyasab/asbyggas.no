# SendGrid (gratis nivå, ca. 100 e-poster/dag) — https://sendgrid.com
# Opprett API-nøkkel og verifiser én avsender (Single Sender) i SendGrid-kontoen.
# Legg inn i Vercel → Settings → Environment Variables (Production).

SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Avsender: e-postadresse du har verifisert under «Sender Authentication» i SendGrid
# (kan være f.eks. din jobb- eller Gmail-adresse til du verifiserer domene)
SENDGRID_FROM_EMAIL=kontakt@asbyggas.no
SENDGRID_FROM_NAME=A.S Bygg AS

# Hvor henvendelsene leveres (valgfritt, standard er info@asbyggas.no)
CONTACT_EMAIL_TO=info@asbyggas.no
